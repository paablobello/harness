{
  "name": "harness-lab",
  "version": "0.1.0",
  "description": "A provider-agnostic coding-agent harness CLI + SDK — explicit context layers, policy-gated tools, hooks, sensors, MCP client, replay tooling.",
  "type": "module",
  "bin": {
    "harness": "./dist/cli/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "agent",
    "llm",
    "cli",
    "harness",
    "claude",
    "anthropic",
    "openai",
    "mcp",
    "coding-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "minimatch": "^10.0.1",
    "openai": "^4.73.1",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.6"
  }
}
